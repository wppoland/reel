#: src/Admin/Settings.php:77
msgid "Reel"
msgstr ""

#: src/Admin/Settings.php:142
msgid "Hover zoom, an accessible lightbox and a featured product video for your WooCommerce gallery — tuned for speed, with no layout shift and no jQuery."
msgstr ""

#: src/Admin/Settings.php:145
msgid "No CLS"
msgstr ""

#: src/Admin/Settings.php:146
msgid "No jQuery"
msgstr ""

#: src/Admin/Settings.php:147
msgid "Accessible"
msgstr ""

#: src/Admin/Settings.php:159
msgid "Gallery zoom & lightbox"
msgstr ""

#: src/Admin/Settings.php:160
msgid "How shoppers explore your product images: magnify on hover and open them full-screen."
msgstr ""

#: src/Admin/Settings.php:167
msgid "Hover zoom"
msgstr ""

#: src/Admin/Settings.php:168
msgid "When a shopper hovers a gallery image, it magnifies in place to reveal detail — great for textures, labels and fine print. The zoom stays inside the image frame, so nothing on the page moves."
msgstr ""

#: src/Admin/Settings.php:171
msgid "Magnify the image on hover"
msgstr ""

#: src/Admin/Settings.php:177
msgid "Zoom strength"
msgstr ""

#: src/Admin/Settings.php:178
msgid "How much the image grows on hover. 1.2× is subtle; 2× is dramatic. Around 1.4–1.6× reads well for most stores."
msgstr ""

#: src/Admin/Settings.php:185
msgid "Magnification factor on hover, from 1.0× (off) to 3.0×."
msgstr ""

#: src/Admin/Settings.php:190
msgid "Disable zoom on touch"
msgstr ""

#: src/Admin/Settings.php:191
msgid "Phones and tablets have no real hover, so the zoom can feel unpredictable. Keep this on to skip it on touch devices and rely on the lightbox there instead."
msgstr ""

#: src/Admin/Settings.php:194
msgid "Skip hover zoom on touch devices"
msgstr ""

#: src/Admin/Settings.php:200
msgid "Lightbox"
msgstr ""

#: src/Admin/Settings.php:201
msgid "Clicking a gallery image opens it full-screen over a dimmed backdrop. Fully keyboard-operable: open with Enter/Space, close with Escape, and focus returns to where it was."
msgstr ""

#: src/Admin/Settings.php:204
msgid "Open images full-screen on click"
msgstr ""

#: src/Admin/Settings.php:210
msgid "Close on backdrop click"
msgstr ""

#: src/Admin/Settings.php:211
msgid "Let shoppers dismiss the lightbox by clicking the dark area around the image, in addition to the close button and Escape key."
msgstr ""

#: src/Admin/Settings.php:214
msgid "Click outside the image to close"
msgstr ""

#: src/Admin/Settings.php:220
msgid "Image caption"
msgstr ""

#: src/Admin/Settings.php:221
msgid "Show each image's alt text as a caption inside the lightbox. Helpful when your images have descriptive alt text; leave off if they don't."
msgstr ""

#: src/Admin/Settings.php:224
msgid "Show the image alt text as a caption"
msgstr ""

#: src/Admin/Settings.php:230
msgid "Open-image label"
msgstr ""

#: src/Admin/Settings.php:231
msgid "The accessible label screen readers announce for each gallery image, e.g. \"Open image in full screen\". Leave empty to use the built-in default."
msgstr ""

#: src/Admin/Settings.php:234
#: src/Service/ReelService.php:55
msgid "Open image in full screen"
msgstr ""

#: src/Admin/Settings.php:236
msgid "Accessible label for the open-in-lightbox control. Leave empty for the default."
msgstr ""

#: src/Admin/Settings.php:246
msgid "Featured video"
msgstr ""

#. translators: %s: the product meta field name.
#: src/Admin/Settings.php:251
#, php-format
msgid "Add a video to any product by setting its %s meta field to a self-hosted MP4/WebM file or a YouTube/Vimeo link."
msgstr ""

#: src/Admin/Settings.php:263
msgid "Show featured video"
msgstr ""

#: src/Admin/Settings.php:264
msgid "Master switch for the product video. When on, products that have a video URL show it on their single product page in the position you choose below."
msgstr ""

#: src/Admin/Settings.php:267
msgid "Display the product video on the product page"
msgstr ""

#: src/Admin/Settings.php:273
msgid "Position"
msgstr ""

#: src/Admin/Settings.php:274
msgid "Where the video appears: directly under the image gallery, or above the title/price summary column. Pick whichever fits your theme best."
msgstr ""

#: src/Admin/Settings.php:278
msgid "After the gallery"
msgstr ""

#: src/Admin/Settings.php:279
msgid "Before the summary"
msgstr ""

#: src/Admin/Settings.php:286
msgid "Autoplay"
msgstr ""

#: src/Admin/Settings.php:287
msgid "Start the video automatically on page load. Browsers only allow this when the video is muted, so sound stays off until the shopper turns it on. Use sparingly — it can be distracting."
msgstr ""

#: src/Admin/Settings.php:290
msgid "Play automatically (muted)"
msgstr ""

#: src/Admin/Settings.php:296
msgid "Show heading"
msgstr ""

#: src/Admin/Settings.php:297
msgid "Display a heading above the video. Turn off for a cleaner, heading-free embed."
msgstr ""

#: src/Admin/Settings.php:300
msgid "Show a heading above the video"
msgstr ""

#: src/Admin/Settings.php:306
msgid "Default heading"
msgstr ""

#: src/Admin/Settings.php:307
msgid "The heading used when a product has no video heading of its own. Leave empty to use the built-in \"Product video\" text."
msgstr ""

#: src/Admin/Settings.php:310
#: src/Service/ReelService.php:72
#: src/Service/ReelService.php:233
msgid "Product video"
msgstr ""

#: src/Admin/Settings.php:316
msgid "Intro text"
msgstr ""

#: src/Admin/Settings.php:317
msgid "An optional short paragraph shown under the heading, e.g. \"See it in action.\" Leave empty to hide it."
msgstr ""

#: src/Admin/Settings.php:320
msgid "See this product in action…"
msgstr ""

#: src/Admin/Settings.php:331
msgid "Place it anywhere"
msgstr ""

#: src/Admin/Settings.php:332
msgid "Beyond the automatic gallery position, drop the current product's video wherever you like."
msgstr ""

#: src/Admin/Settings.php:337
msgid "Shortcode"
msgstr ""

#: src/Admin/Settings.php:341
msgid "Paste into any product description or page. Optional attributes: id=\"123\" to target a specific product, and title=\"hide\" to drop the heading."
msgstr ""

#: src/Admin/Settings.php:344
msgid "Block"
msgstr ""

#: src/Admin/Settings.php:346
#: src/Frontend/VideoShortcode.php:70
#: src/Frontend/VideoShortcode.php:118
msgid "Reel: Featured video"
msgstr ""

#: src/Admin/Settings.php:348
msgid "Search for it in the block inserter. Renders the same video as the shortcode."
msgstr ""

#: src/Admin/Settings.php:355
msgid "Save changes"
msgstr ""

#: src/Frontend/VideoShortcode.php:73
msgid "Show the current product's featured video (Reel)."
msgstr ""

#: src/Frontend/VideoShortcode.php:119
msgid "This shows the current product's video on the storefront. Set a video URL in the product's _reel_video_url meta field, then view the product page."
msgstr ""

